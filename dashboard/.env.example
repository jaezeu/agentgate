# All VITE_* values are public build-time configuration. Never put secrets here.
VITE_AGENTGATE_API_BASE_URL=http://localhost:8080/
VITE_AUTH_MODE=oidc
VITE_OIDC_AUTHORITY=https://identity.example.test/
VITE_OIDC_CLIENT_ID=agentgate-dashboard
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
VITE_OIDC_SCOPE=openid profile email

# Development-only alternative. Both values are required and production builds
# reject mock mode.
# VITE_AUTH_MODE=mock
# VITE_ENABLE_MOCK_AUTH=true
# VITE_MOCK_SUBJECT=operator@example.test
